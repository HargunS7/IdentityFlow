# =============================================================================
# FRONTEND ENVIRONMENT — copy to frontend/.env. SAFE / PUBLIC values only.
# =============================================================================
# Vite inlines every VITE_-prefixed variable into the browser bundle.
# NEVER put a secret (DB URL, JWT secret, service-role key) here.

# Base URL of the Express backend API.
# Local:      http://localhost:3000
# Production: https://your-backend-host.example.com
VITE_API_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Intentionally NO VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY.
# The browser talks only to the Express backend, never to Supabase directly.
# -----------------------------------------------------------------------------
