# =============================================================================
# BACKEND ENVIRONMENT — copy to backend/.env and fill in. NEVER commit .env.
# =============================================================================
# All database access goes through Prisma using these connection strings.
# The browser never connects to the database directly.

# ----- Database (Supabase Postgres, via Prisma) -----
# Pooled connection (PgBouncer, port 6543) — used by the running app.
# Supabase dashboard → Project Settings → Database → Connection string → "Transaction" pooler.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (port 5432) — used ONLY by the Prisma CLI for migrations.
# Supabase dashboard → ... → "Direct connection".
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ----- Auth / crypto -----
# Must be at least 32 bytes. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-string-min-32-bytes"
# Access-token lifetime (jsonwebtoken format). Sessions are still revocable server-side.
JWT_EXPIRES_IN="1h"

# ----- App config -----
# Exact origin of the frontend, used for CORS. No trailing slash.
# Production example: https://your-frontend.vercel.app
FRONTEND_ORIGIN="http://localhost:5173"
PORT=3000
# "production" disables debug routes, forces Secure cookies, and enforces
# strict env validation (e.g. rejects a weak JWT_SECRET).
NODE_ENV="development"

# ----- Cookies (cross-domain hosting) -----
# Leave unset for local dev. In production the backend defaults to
# SameSite=None; Secure, which is REQUIRED when the frontend and backend are on
# different domains. Override to "lax" only if they share the same site.
# COOKIE_SAMESITE="none"
# Set only if frontend+backend share a parent domain and you want one cookie
# across subdomains, e.g. ".example.com". Otherwise leave unset.
# COOKIE_DOMAIN=""

# -----------------------------------------------------------------------------
# NOTE: No SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY needed.
# This project does NOT use the Supabase JS client or the Supabase Data API.
# Access is Prisma → Postgres only. Do not reintroduce Supabase keys here.
# -----------------------------------------------------------------------------
